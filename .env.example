# ── Telegram ──────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here

# ── Admin Telegram IDs (comma-separated) ──────────────
# These users will have access to all admin commands.
ADMIN_IDS=123456789,987654321

# ── MongoDB ───────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/
MONGO_DB_NAME=telegram_mail_bot

# ── IMAP (Gmail catch-all) ────────────────────────────
IMAP_USER=yourcatchall@gmail.com
IMAP_PASS=yourgoogleapppassword
